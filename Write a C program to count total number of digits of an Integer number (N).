#include <stdio.h>
 int main()
{
    int N; 
    scanf("%d",&N); 
       int temp = N;
    int count = 0;

    if(temp < 0)
        temp = -temp;

    if(temp == 0)
        count = 1;
    else
    {
        while(temp != 0)
        {
            temp = temp / 10;
            count++;
        }
    }

    printf("The number %d contains %d digits.",N,count);

    return 0;
}
